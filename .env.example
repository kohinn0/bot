# =============================================================
# SebessegBot - Hyperliquid konfigurációs sablon
# Másold le ezt a fájlt .env névre és töltsd ki az értékeket
# cp .env.example .env
# =============================================================

# Hyperliquid privát kulcs (SOHA ne commitold be!)
PRIVATE_KEY=0x_id_be_a_sajat_private_kulcsodat

# Kereskedési mód: true = szimuláció, false = éles
DRY_RUN=true

# Stratégia config fájl
STRATEGY_CONFIG=strategy_maker.json